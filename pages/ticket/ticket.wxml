<view class="card">
  <view class="row">
    <view class="title" style="font-size:30rpx;">我的申请</view>
    <view class="btn-ghost" style="padding:10rpx 16rpx;" bindtap="goCreate">新建</view>
  </view>

  <view style="margin-top:12rpx;">
    <view wx:for="{{items}}" wx:key="id" style="padding:14rpx 0; border-bottom:1rpx solid #eee;" bindtap="open" data-id="{{item.id}}">
      <view class="row">
        <view>{{item.typeName}}</view>
        <view class="muted">{{item.status}}</view>
      </view>
      <view class="muted" style="margin-top:6rpx;">{{item.createTime}}</view>
      <view class="muted" style="margin-top:6rpx;">事由：{{item.reason}}</view>
    </view>
  </view>
</view>